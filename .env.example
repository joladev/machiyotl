# JSON config of sites, single line, e.g.:
# SITES_CONFIG={"larm":{"theme":{"siteName":"Larm","bg":"#FAF9F6","fg":"#171717","accent":"#DC2828","logoUrl":"https://..."}}}
SITES_CONFIG=

# Single secret used to sign all site signatures
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Set to "development" to enable ?preview=1 bypass
NODE_ENV=production

# Optional, defaults to 3000
PORT=3000
